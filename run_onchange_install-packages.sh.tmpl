#!/bin/sh
# Packages: starship fzf zoxide eza yazi fd neovim btop fastfetch
# Edit the line above to add/remove packages — chezmoi re-runs this script when the file changes.

{{ if eq .chezmoi.os "darwin" -}}
eval "$(/opt/homebrew/bin/brew shellenv 2>/dev/null || /usr/local/bin/brew shellenv 2>/dev/null)"

PACKAGES="starship fzf zoxide eza yazi fd neovim btop fastfetch"
for pkg in $PACKAGES; do
    brew list --formula "$pkg" >/dev/null 2>&1 || brew install "$pkg"
done
brew list --formula openjdk@17 >/dev/null 2>&1 || brew install openjdk@17

{{ else if eq .chezmoi.os "linux" -}}
export PATH="$HOME/.local/bin:$PATH"

PACKAGES="starship fzf zoxide eza yazi fd neovim btop fastfetch"
for pkg in $PACKAGES; do
    mise ls "$pkg" >/dev/null 2>&1 || mise use --global "$pkg@latest"
done
{{ end -}}
